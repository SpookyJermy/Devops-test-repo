{
  "name": "mountainpulse",
  "version": "1.0.0",
  "description": "MountainPulse Adventure Club - Kinetic Typography Design System with Tailwind CSS",
  "main": "index.js",
  "scripts": {
    "build": "tailwindcss -i ./CSS/input.css -o ./CSS/style.css",
    "watch": "tailwindcss -i ./CSS/input.css -o ./CSS/style.css --watch",
    "dev": "concurrently \"npm run watch\" \"echo 'Open pages in browser'\"",
    "production": "cross-env NODE_ENV=production npm run build"
  },
  "keywords": [
    "adventure",
    "mountaineering",
    "tailwind",
    "kinetic-typography"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.31",
    "postcss-nesting": "^14.0.0",
    "tailwindcss": "^3.4.0"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.5.4"
  }
}
